# Copy this file to .env and adjust as needed.

# PostgreSQL (matches docker-compose.yml host port mapping)
DATABASE_URL=postgresql+psycopg2://dream_hub:dream_hub_password@localhost:5433/dream_hub_db

# Redis (matches docker-compose.yml host port mapping)
REDIS_URL=redis://localhost:6380/0

# Auth
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Session (구글 OAuth state/nonce 저장용 서명 키 - JWT_SECRET_KEY와 다른 값 권장)
SESSION_SECRET_KEY=change-this-session-secret

# 이메일 인증 (SMTP)
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@dreamhub.dev
SMTP_FROM_NAME=Dream Hub

# 구글 OAuth 2.0 (Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
